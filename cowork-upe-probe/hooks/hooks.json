{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "echo UPE_PROBE_SESSIONSTART=ok" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "echo UPE_PROBE_PROMPTSUBMIT=ok" }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "hooks": [
          { "type": "command", "command": "echo UPE_PROBE_EXPANSION=fired" }
        ]
      }
    ]
  }
}
