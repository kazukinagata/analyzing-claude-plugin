{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "echo DP_CONTROL=static_marker_no_var" },
          { "type": "command", "command": "echo DP_DATA_PATH=${CLAUDE_PLUGIN_DATA}" },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/persist.sh\"" }
        ]
      }
    ]
  }
}
